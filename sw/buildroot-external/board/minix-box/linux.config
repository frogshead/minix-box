#
# minix-box kernel config — STARTER (defconfig fragment, ARMv5TE / suniv).
#
# ⚠ THIS IS A STARTING POINT, NOT A VALIDATED FULL CONFIG.
#   suniv (F1C100s/F1C200s) is ARMv5TE and is NOT covered by the generic v7
#   sunxi_defconfig. Buildroot copies this file to .config and runs `oldconfig`,
#   filling unspecified symbols with defaults. Before relying on the image:
#     1) build once, then `make linux-menuconfig` to enable/verify drivers,
#     2) `make linux-update-defconfig` to regenerate a complete, validated config,
#     3) commit the result back over this file.
#   Alternatively, seed from the proven unframework/licheepi-nano kernel defconfig.
#
# Essential symbols for this board:

# Architecture: ARMv5 multiplatform + Allwinner suniv
CONFIG_ARCH_MULTI_V5=y
CONFIG_ARCH_SUNXI=y
CONFIG_MACH_SUNIV=y
CONFIG_AEABI=y

# Boot / console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y

# microSD (SDC0)
CONFIG_MMC=y
CONFIG_MMC_SUNXI=y
CONFIG_MMC_BLOCK=y

# SPI + SPI-NOR (boot flash)
CONFIG_SPI=y
CONFIG_SPI_SUN6I=y
CONFIG_MTD=y
CONFIG_MTD_BLOCK=y
CONFIG_MTD_SPI_NOR=y

# USB-OTG (musb) + gadget (g_serial/g_ether over USB-C)
CONFIG_USB=y
CONFIG_USB_MUSB_HDRC=y
CONFIG_USB_MUSB_SUNXI=y
CONFIG_USB_GADGET=y
CONFIG_USB_ETH=y

# Status LED
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_TRIGGERS=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y

# Filesystems / rootfs
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_TMPFS=y

# Keep it small: no DRM/framebuffer/sound on the base console image.
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_SOUND is not set
