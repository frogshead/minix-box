# minix-box U-Boot config overrides, applied on top of lctech_pi_f1c200s_defconfig.
#
# lctech_pi_f1c200s_defconfig already sets CONFIG_SUNXI_MINIMUM_DRAM_MB=64
# for the F1C200s in-package 64 MB DDR.

# Console on UART0 (the lctech board uses UART1 / CONS_INDEX=2).
CONFIG_CONS_INDEX=1

# Boot delay.
CONFIG_BOOTDELAY=1

# SPI flash support for boot from W25Q128 on SPI0.
CONFIG_SPL_SPI_SUNXI=y
CONFIG_SPI_FLASH_WINBOND=y
